@model EduLog.Models.Account.RegisterStudentViewModel

@{
    ViewData["Title"] = "Активація акаунта учня";
    var initials = string.Concat(
        Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(p => p.Length > 0 ? p[0] : ' ')
    ).Trim().ToUpperInvariant();
}

<link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />

<style>
    .register-student-bg {
        min-height: calc(100vh - 100px);
        background: linear-gradient(135deg, #6f42c1 0%, #4d2d8c 50%, #ff9800 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        margin: -1rem -12px 0;
    }

    .register-card {
        background: white;
        border-radius: 24px;
        max-width: 480px;
        width: 100%;
        padding: 2.5rem 2rem 2rem;
        box-shadow: 0 16px 48px rgba(0,0,0,0.2);
        position: relative;
        overflow: hidden;
    }
    .register-card::before {
        content: "";
        position: absolute;
        top: -60px; right: -60px;
        width: 220px; height: 220px;
        background: radial-gradient(circle, rgba(255,193,7,0.3) 0%, transparent 70%);
    }
    .register-card::after {
        content: "";
        position: absolute;
        bottom: -80px; left: -80px;
        width: 240px; height: 240px;
        background: radial-gradient(circle, rgba(111,66,193,0.2) 0%, transparent 70%);
    }
    .register-card > * { position: relative; z-index: 1; }

    .floating-coins {
        position: absolute; top: 10px; left: 10px;
        font-size: 1.4rem;
        animation: float 3s ease-in-out infinite;
    }
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }

    .welcome-title {
        background: linear-gradient(135deg, #6f42c1 0%, #ff9800 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 800;
    }

    .student-info-card {
        background: linear-gradient(135deg, #fff8e7 0%, #f5f0ff 100%);
        border-radius: 16px;
        padding: 1.2rem;
        text-align: center;
        margin: 1rem 0 1.5rem;
        border: 2px dashed #ffc107;
    }

    .start-quest-btn {
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
        color: white;
        border: none;
        font-weight: 700;
        padding: 0.85rem;
        border-radius: 12px;
        font-size: 1.1rem;
        box-shadow: 0 4px 16px rgba(255,152,0,0.4);
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .start-quest-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 22px rgba(255,152,0,0.55);
        color: white;
    }

    .perks { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin: 1.5rem 0; }
    .perk { background: #f8f5ff; border-radius: 10px; padding: 0.6rem; text-align: center; font-size: 0.85rem; }
    .perk-icon { font-size: 1.4rem; }
</style>

<div class="register-student-bg">
    <div class="register-card">
        <div class="floating-coins">🪙</div>

        <div class="text-center mb-3">
            <div class="student-avatar student-avatar-large mx-auto mb-3">@initials</div>
            <h2 class="welcome-title mb-1">Ласкаво просимо!</h2>
            <p class="text-muted mb-0">Створи свій акаунт, щоб увійти в гру</p>
        </div>

        <div class="student-info-card">
            <h5 class="mb-2">@Model.FullName</h5>
            <p class="mb-1"><i class="bi bi-mortarboard text-primary"></i> @Model.SchoolName</p>
            <p class="mb-0"><i class="bi bi-people text-primary"></i> @Model.ClassName клас</p>
        </div>

        <div class="perks">
            <div class="perk">
                <div class="perk-icon">🔥</div>
                Стріки за відвідуваність
            </div>
            <div class="perk">
                <div class="perk-icon">🪙</div>
                EduCoins за оцінки
            </div>
            <div class="perk">
                <div class="perk-icon">🏆</div>
                Досягнення та рівні
            </div>
            <div class="perk">
                <div class="perk-icon">📊</div>
                Рейтинг класу
            </div>
        </div>

        <form asp-action="RegisterStudent" asp-controller="Account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="FullName" />
            <input type="hidden" asp-for="ClassName" />
            <input type="hidden" asp-for="SchoolName" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label">📧 Email</label>
                <input asp-for="Email" class="form-control form-control-lg" readonly />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">🔐 Пароль</label>
                <input asp-for="Password" class="form-control form-control-lg" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">🔁 Підтвердіть пароль</label>
                <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="start-quest-btn w-100">
                ⚡ Почати пригоду
            </button>
        </form>

        <p class="text-center text-muted small mt-3 mb-0">
            Вже маєш акаунт? <a asp-action="Login" asp-controller="Account">Увійти</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
