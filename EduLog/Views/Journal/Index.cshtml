@model EduLog.Models.JournalView
@{
    var today = DateTime.Today;
}
<
<h1>Журнал: @Model.Class.Name (@Model.Subject.Name)</h1>

<link rel="stylesheet" href="~/css/Journal.css" asp-append-version="true" />

<div class="btn-group mb-3" role="group" aria-label="Вигляд журналу">
    @if (ViewBag.ViewMode == "day")
    {
        <button type="button" class="btn btn-primary active" disabled>
            День <i class="bi bi-calendar-date"></i>
        </button>
    }
    else
    {
        <a class="btn btn-outline-primary"
           asp-action="Index"
           asp-route-classId="@Model.Class.Id"
           asp-route-subjectId="@Model.Subject.Id"
           asp-route-viewMode="day">
            День <i class="bi bi-calendar-date"></i>
        </a>
    }

    @if (ViewBag.ViewMode == "week")
    {
        <button type="button" class="btn btn-primary active" disabled>
            Тиждень <i class="bi bi-5-square"></i>
        </button>
    }
    else
    {
        <a class="btn btn-outline-primary "
           asp-action="Index"
           asp-route-classId="@Model.Class.Id"
           asp-route-subjectId="@Model.Subject.Id"
           asp-route-viewMode="week">
            Тиждень <i class="bi bi-5-square"></i>
        </a>
    }

    @if (ViewBag.ViewMode == "month")
    {
        <button type="button" class="btn btn-primary active" disabled>
            Місяць <i class="bi bi-calendar3"></i>
        </button>
    }
    else
    {
        <a class="btn btn-outline-primary disabled"
           asp-action="Index"
           asp-route-classId="@Model.Class.Id"
           asp-route-subjectId="@Model.Subject.Id"
           asp-route-viewMode="month">
            Місяць <i class="bi bi-calendar3"></i>
        </a>
    }
</div>
<div class="table-responsive">
    <table class="table table-bordered align-middle text-center">
        <thead>
            <tr>
                <th class="sticky-col">Учень</th>
                @foreach (var day in Model.Days)
                {
                    <th class="@(day.Date == today ? "table-primary" : "")">
                        @day.ToString("ddd")<br />@day.ToString("dd.MM")
                    </th>
                }

                @*@foreach (var custom in Model.CustomColumns)
                    {
                        <th>@custom.Name</th>
                    }*@
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model.Students)
            {
                <tr>
                    <td class="text-start sticky-col">@student.Surname @student.Name</td>
                    @foreach (var day in Model.Days)
                    {
                        var grade = Model.GetGrade(student.Id, day, Model.Subject.Id);
                        var absence = Model.GetAbsence(student.Id, day, Model.Subject.Id);
                        <td class="p-0">
                            <input type="text"
                                   class="form-control form-control-sm text-center "
                                   value="@grade"
                                   data-student="@student.Id"
                                   data-date="@day.ToString("yyyy-MM-dd")"
                                   data-type="grade"
                                   onchange="saveCell(this)"
                                   style="width: 50px; display: inline-block;" />
                            @*<input type="checkbox"
                                title="Відмітити відсутність"
                                data-student="@student.Id"
                                data-date="@day.ToString("yyyy-MM-dd")"
                                data-type="absence"
                                onchange="saveCell(this)"
                                @(absence != null ? "checked" : "") />*@
                        </td>
                    }
                    @*@foreach (var custom in Model.CustomColumns)
                        {
                            var customGrade = Model.GetCustomGrade(student.Id, custom.Id);
                            <td class="p-1">
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="@(customGrade?.Value ?? "")"
                                       data-student="@student.Id"
                                       data-custom="@custom.Id"
                                       data-type="custom"
                                       onchange="saveCell(this)"
                                       style="width: 50px; display: inline-block;" />
                            </td>
                        }*@
                </tr>
            }
        </tbody>
    </table>
</div>



@section Scripts
{
    <script>
    function saveCell(input) {
    let data = {
        studentId: input.dataset.student,
        subjectId: '@Model.Subject.Id', // Додаємо subjectId
        date: input.dataset.date,
        type: input.dataset.type,
        value: input.type === "checkbox" ? input.checked : input.value
    };
    fetch('@Url.Action("SaveCell", "Journal")', {
        method: "POST",
        headers: { "Content-Type": "application/json", "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
        body: JSON.stringify(data)
    });
}
    </script>
}

