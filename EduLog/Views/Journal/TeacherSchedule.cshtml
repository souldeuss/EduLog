@using EduLog.Models
@{
    ViewData["Title"] = "Мій розклад";

    var noTeacherLinked = ViewData["NoTeacherLinked"] as bool? ?? false;
    var slots = ViewData["ScheduleSlots"] as List<TeacherScheduleSlotView> ?? new();
    var selectedYear = ViewData["SelectedYear"] as AcademicYear;
    var subjectColors = ViewData["SubjectColors"] as Dictionary<string, string> ?? new();

    string[] dayNames = { "Понеділок", "Вівторок", "Середа", "Четвер", "П'ятниця" };
    int maxLesson = Math.Max(slots.Any() ? slots.Max(s => s.LessonNumber) : 0, 8);

    var today = DateTime.Today;
    int diff = (int)today.DayOfWeek - (int)DayOfWeek.Monday;
    if (diff < 0) diff += 7;
    var monday = today.AddDays(-diff);
    var friday = monday.AddDays(4);
}

<style>
    .ts-table th, .ts-table td {
        vertical-align: middle;
    }

    .ts-lesson-card {
        border-radius: .5rem;
        padding: .45rem .6rem;
        margin-bottom: .25rem;
        text-align: left;
        transition: box-shadow .15s;
    }

    .ts-lesson-card:last-child {
        margin-bottom: 0;
    }

    .ts-lesson-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,.15);
    }

    .ts-empty {
        color: #adb5bd;
        font-size: 1.1rem;
        letter-spacing: .05em;
    }

    .ts-legend-dot {
        display: inline-block;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,.12);
        flex-shrink: 0;
    }
</style>

<div class="d-flex align-items-center gap-3 mb-2 flex-wrap">
    <h2 class="mb-0"><i class="bi bi-calendar-week"></i> Мій розклад</h2>
    @if (selectedYear != null)
    {
        <span class="badge bg-secondary fs-6 fw-normal">
            <i class="bi bi-calendar-range"></i> @selectedYear.Name
        </span>
    }
    <span class="badge bg-light text-dark border fs-6 fw-normal">
        <i class="bi bi-calendar3"></i> @monday.ToString("dd.MM") – @friday.ToString("dd.MM.yyyy")
    </span>
</div>

@if (noTeacherLinked)
{
    <div class="alert alert-warning d-flex align-items-start gap-2 mt-3">
        <i class="bi bi-exclamation-triangle-fill fs-5 mt-1"></i>
        <div>
            <strong>Профіль вчителя не прив'язано.</strong><br />
            Щоб бачити власний розклад, необхідно прив'язати ваш обліковий запис до профілю вчителя.
            Зверніться до адміністратора школи або перейдіть до розділу
            <a asp-controller="Admin" asp-action="Teachers">Вчителі</a>
            та встановіть зв'язок між обліковим записом і профілем вчителя.
        </div>
    </div>
}
else if (!slots.Any())
{
    <div class="alert alert-info mt-3">Розклад ще не сформовано.</div>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table table-bordered ts-table">
            <thead class="table-dark text-center">
                <tr>
                    <th style="width:42px">#</th>
                    @for (var day = 1; day <= 5; day++)
                    {
                        <th>@dayNames[day - 1]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (var lesson = 1; lesson <= maxLesson; lesson++)
                {
                    <tr>
                        <th class="table-secondary text-center fw-bold fs-6 align-middle">@lesson</th>
                        @for (var day = 1; day <= 5; day++)
                        {
                            var daySlots = slots.Where(s => s.DayOfWeek == day && s.LessonNumber == lesson).ToList();
                            if (daySlots.Count == 0)
                            {
                                <td class="text-center ts-empty align-middle" style="background:#f8f9fa">—</td>
                            }
                            else
                            {
                                <td class="p-1 align-middle">
                                    @foreach (var slot in daySlots)
                                    {
                                        var color = subjectColors.TryGetValue(slot.SubjectName, out var c) ? c : "#6C757D";
                                        <div class="ts-lesson-card"
                                             style="background-color:@(color)26; border-left:4px solid @color;">
                                            <div class="fw-bold" style="font-size:.85rem">
                                                <i class="bi bi-book"></i> @slot.SubjectName
                                            </div>
                                            <div class="text-muted" style="font-size:.78rem">@slot.ClassName</div>
                                            @if (!string.IsNullOrWhiteSpace(slot.Room))
                                            {
                                                <div class="text-muted" style="font-size:.75rem">
                                                    <i class="bi bi-door-open"></i> @slot.Room
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (subjectColors.Any())
    {
        <div class="card border-0 shadow-sm p-3">
            <div class="fw-semibold mb-2 text-muted" style="font-size:.85rem">
                <i class="bi bi-palette"></i> ЛЕГЕНДА ПРЕДМЕТІВ
            </div>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var kv in subjectColors.OrderBy(x => x.Key))
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="ts-legend-dot" style="background-color:@kv.Value"></span>
                        <span style="font-size:.88rem">@kv.Key</span>
                    </div>
                }
            </div>
        </div>
    }
}
