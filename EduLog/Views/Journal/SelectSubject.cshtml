@model List<Subject>
@{
    var selectcls = ViewData["Class"] as Class;
    var classList = ViewData["Classes"] as List<Class>;
    var cardColors = new[] { "bg-warning", "bg-success", "bg-primary" };
}
<h1>Оберіть предмет</h1>

<form method="get" asp-controller="Journal" asp-action="SelectSubject" class="mb-4">
    <div class="input-group" style="max-width: 300px;">
        <select class="form-select" name="classId" onchange="this.form.submit()">
            <option value="@selectcls?.Id">@selectcls?.Name</option>
            @if (classList != null && classList.Count > 0)
            {
                foreach (var cls in classList)
                {
                    var selected = selectcls != null && cls.Id == selectcls.Id ? "selected" : "";
                    <option value="@cls.Id" selected="@selected">@cls.Name</option>
                }
            }
        </select>
    </div>
</form>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mb-3">
    @for (int i = 0; i < Model.Count; i++)
    {
        var subject = Model[i];
        var colorClass = cardColors[i % cardColors.Length];
        <div class="col">
            <a asp-controller="Journal" asp-action="Index" asp-route-classId="@selectcls?.Id" asp-route-subjectId="@subject.Id" class="text-decoration-none">
                <div class="card h-100 text-center align-items-center justify-content-center d-flex @colorClass text-white" style="cursor:pointer; min-height: 120px;">
                    <span class="fw-bold fs-4">@subject.Name</span>
                </div>
            </a>
        </div>
    }
</div>