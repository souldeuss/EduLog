@model EduLog.Models.StudentArea.AvatarVm

@if (!string.IsNullOrEmpty(Model.AvatarPath))
{
    <div class="student-avatar @Model.SizeClass" style="background: white; padding: 0; overflow: hidden;">
        <img src="@Model.AvatarPath" alt="avatar"
             style="width: 100%; height: 100%; object-fit: cover; display: block;" />
    </div>
}
else
{
    <div class="student-avatar @Model.SizeClass">@Model.Initials</div>
}
