@using System.Text.Json
@{
    ViewData["Title"] = "Адмін-панель";
    int classCount = (int)(ViewData["ClassCount"] ?? 0);
    int teacherCount = (int)(ViewData["TeacherCount"] ?? 0);
    int studentCount = (int)(ViewData["StudentCount"] ?? 0);
    int subjectCount = (int)(ViewData["SubjectCount"] ?? 0);
    var events = ViewData["Events"] as List<EduLog.Models.SchoolEvent> ?? new List<EduLog.Models.SchoolEvent>();
    var currentMonth = (DateTime)(ViewData["CurrentMonth"] ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1));

    var monthStart = new DateTime(currentMonth.Year, currentMonth.Month, 1);
    var monthEnd = monthStart.AddMonths(1).AddDays(-1);
    int monthStartOffset = ((int)monthStart.DayOfWeek + 6) % 7;
    int monthEndOffset = 6 - (((int)monthEnd.DayOfWeek + 6) % 7);
    var gridStart = monthStart.AddDays(-monthStartOffset);
    var gridEnd = monthEnd.AddDays(monthEndOffset);
    int totalDays = (gridEnd - gridStart).Days + 1;
    var eventsByDate = events
        .GroupBy(e => e.Date.Date)
        .ToDictionary(g => g.Key, g => g.OrderBy(e => e.Title).ToList());

    var eventsJson = JsonSerializer.Serialize(events.Select(e => new
    {
        id = e.Id,
        title = e.Title,
        date = e.Date.ToString("yyyy-MM-dd"),
        color = e.Color
    }));
}

<style>
    .dashboard-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .dashboard-card-link .card {
        transition: transform .15s ease, box-shadow .15s ease;
        cursor: pointer;
    }

    .dashboard-card-link:hover .card {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15);
    }

    .events-calendar {
        border: 1px solid var(--bs-border-color);
        border-radius: .75rem;
        overflow: hidden;
    }

    .calendar-weekdays,
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
    }

    .calendar-weekdays > div {
        background: var(--bs-light-bg-subtle);
        border-bottom: 1px solid var(--bs-border-color);
        text-align: center;
        font-size: .8rem;
        font-weight: 600;
        padding: .45rem;
    }

    .calendar-day {
        min-height: 92px;
        border-right: 1px solid var(--bs-border-color);
        border-bottom: 1px solid var(--bs-border-color);
        padding: .35rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .calendar-day:nth-child(7n) {
        border-right: none;
    }

    .calendar-day.other-month {
        background: var(--bs-tertiary-bg);
        color: var(--bs-secondary-color);
    }

    .calendar-day.empty-current-month {
        cursor: pointer;
    }

    .calendar-day.empty-current-month:hover {
        background: #f4f9ff;
    }

    .event-list {
        display: flex;
        flex-direction: column;
        gap: .2rem;
        overflow: hidden;
    }

    .event-chip {
        border: 0;
        border-radius: .35rem;
        padding: .15rem .35rem;
        font-size: .72rem;
        text-align: left;
        color: #fff;
        background: #0d6efd;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        cursor: pointer;
    }

    .calendar-toolbar {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

</style>

<partial name="_AdminNav" />

<h2 class="mb-4">Панель керування</h2>

<div class="row g-4">
    <div class="col-md-3">
        <a asp-action="Classes" class="dashboard-card-link">
            <div class="card text-bg-primary">
                <div class="card-body text-center">
                    <i class="bi bi-collection fs-1"></i>
                    <h3 class="mt-2">@classCount</h3>
                    <p class="mb-0">Класів</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Teachers" class="dashboard-card-link">
            <div class="card text-bg-success">
                <div class="card-body text-center">
                    <i class="bi bi-people fs-1"></i>
                    <h3 class="mt-2">@teacherCount</h3>
                    <p class="mb-0">Вчителів</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Classes" class="dashboard-card-link">
            <div class="card text-bg-info">
                <div class="card-body text-center">
                    <i class="bi bi-mortarboard fs-1"></i>
                    <h3 class="mt-2">@studentCount</h3>
                    <p class="mb-0">Учнів</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Subjects" class="dashboard-card-link">
            <div class="card text-bg-warning">
                <div class="card-body text-center">
                    <i class="bi bi-book fs-1"></i>
                    <h3 class="mt-2">@subjectCount</h3>
                    <p class="mb-0">Предметів</p>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Події школи</h5>
        <div class="calendar-toolbar">
            <button type="button" class="btn btn-outline-secondary btn-sm" id="prevMonthBtn">&larr;</button>
            <span class="text-muted small" id="currentMonthLabel">@monthStart.ToString("MMMM yyyy")</span>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="nextMonthBtn">&rarr;</button>
        </div>
    </div>

    <div class="events-calendar">
        <div class="calendar-weekdays">
            <div>Пн</div>
            <div>Вт</div>
            <div>Ср</div>
            <div>Чт</div>
            <div>Пт</div>
            <div>Сб</div>
            <div>Нд</div>
        </div>

        <div class="calendar-grid" id="calendarGrid" data-current-month="@monthStart.ToString("yyyy-MM-dd")">
            @for (var i = 0; i < totalDays; i++)
            {
                var day = gridStart.AddDays(i);
                var inCurrentMonth = day.Month == monthStart.Month;
                var dayEvents = eventsByDate.TryGetValue(day.Date, out var list) ? list : new List<EduLog.Models.SchoolEvent>();
                var isEmptyCurrentMonth = inCurrentMonth && !dayEvents.Any();

                <div class="calendar-day @(inCurrentMonth ? "" : "other-month") @(isEmptyCurrentMonth ? "empty-current-month" : "")"
                     data-date="@day.ToString("yyyy-MM-dd")"
                     data-in-month="@(inCurrentMonth ? "1" : "0")"
                     data-has-events="@(dayEvents.Any() ? "1" : "0")">
                    <div class="small fw-semibold">@day.Day</div>
                    <div class="event-list">
                        @foreach (var ev in dayEvents)
                        {
                            <button type="button"
                                    class="event-chip"
                                    data-event-id="@ev.Id"
                                    data-date="@ev.Date.ToString("yyyy-MM-dd")"
                                    data-title="@ev.Title"
                                    data-color="@ev.Color"
                                    style="@(string.IsNullOrWhiteSpace(ev.Color) ? null : $"background:{ev.Color};")"
                                    title="Натисніть, щоб редагувати">
                                @ev.Title
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="eventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Нова подія</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="small text-muted mb-2">Дата: <span id="eventDateLabel"></span></div>
                <input type="hidden" id="eventIdInput" />
                <input type="hidden" id="eventDateInput" />
                <div class="small mb-2 d-none" id="selectedEventTitleRow">Поточна назва: <span id="selectedEventTitle"></span></div>
                <div class="d-flex gap-2 mb-2" id="eventActionButtons">
                    <button type="button" class="btn btn-primary btn-sm d-none" id="startAddModeBtn">Додати</button>
                    <button type="button" class="btn btn-primary btn-sm d-none" id="startEditModeBtn">Редагувати</button>
                </div>
                <div class="mb-2 d-none" id="eventEditorFields">
                    <label class="form-label small">Назва</label>
                    <input type="text" id="eventTitleInput" class="form-control form-control-sm" maxlength="100" />
                    <label class="form-label small">Колір (необов'язково)</label>
                    <input type="color" id="eventColorInput" class="form-control form-control-color" value="#0d6efd" />
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-outline-danger btn-sm me-auto d-none" id="deleteEventBtn">Видалити</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Скасувати</button>
                <button type="button" class="btn btn-primary btn-sm d-none" id="saveEventBtn">Зберегти</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var eventsData = @Html.Raw(eventsJson);
    var createEventUrl = '@Url.Action("CreateEvent", "Admin")';
    var updateEventUrl = '@Url.Action("UpdateEvent", "Admin")';
    var deleteEventUrl = '@Url.Action("DeleteEvent", "Admin")';
    var getEventsUrl = '@Url.Action("GetEvents", "Admin")';
    var calendarGrid = document.getElementById('calendarGrid');
    var currentMonthLabel = document.getElementById('currentMonthLabel');
    var prevMonthBtn = document.getElementById('prevMonthBtn');
    var nextMonthBtn = document.getElementById('nextMonthBtn');
    var eventModalEl = document.getElementById('eventModal');
    var eventModal = new bootstrap.Modal(eventModalEl);
    var eventIdInput = document.getElementById('eventIdInput');
    var eventDateInput = document.getElementById('eventDateInput');
    var eventDateLabel = document.getElementById('eventDateLabel');
    var eventTitleInput = document.getElementById('eventTitleInput');
    var eventColorInput = document.getElementById('eventColorInput');
    var selectedEventTitleRow = document.getElementById('selectedEventTitleRow');
    var selectedEventTitle = document.getElementById('selectedEventTitle');
    var eventEditorFields = document.getElementById('eventEditorFields');
    var startAddModeBtn = document.getElementById('startAddModeBtn');
    var startEditModeBtn = document.getElementById('startEditModeBtn');
    var deleteEventBtn = document.getElementById('deleteEventBtn');
    var saveEventBtn = document.getElementById('saveEventBtn');
    var modalMode = 'create';
    var currentMonth = new Date(calendarGrid.dataset.currentMonth + 'T00:00:00');

    function escapeHtml(text) {
        return (text || '').replace(/[&<>"']/g, function (ch) {
            return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[ch];
        });
    }

    function formatMonthLabel(date) {
        var value = new Intl.DateTimeFormat('uk-UA', { month: 'long', year: 'numeric' }).format(date);
        return value.charAt(0).toUpperCase() + value.slice(1);
    }

    function toMonthStart(date) {
        return new Date(date.getFullYear(), date.getMonth(), 1);
    }

    function toIsoDate(date) {
        var y = date.getFullYear();
        var m = String(date.getMonth() + 1).padStart(2, '0');
        var d = String(date.getDate()).padStart(2, '0');
        return y + '-' + m + '-' + d;
    }

    function setEditorVisible(visible) {
        eventEditorFields.classList.toggle('d-none', !visible);
        saveEventBtn.classList.toggle('d-none', !visible);
    }

    function renderCalendar(monthDate, events) {
        var monthStart = toMonthStart(monthDate);
        var monthEnd = new Date(monthStart.getFullYear(), monthStart.getMonth() + 1, 0);
        var monthStartOffset = (monthStart.getDay() + 6) % 7;
        var monthEndOffset = 6 - ((monthEnd.getDay() + 6) % 7);
        var gridStart = new Date(monthStart);
        gridStart.setDate(monthStart.getDate() - monthStartOffset);
        var gridEnd = new Date(monthEnd);
        gridEnd.setDate(monthEnd.getDate() + monthEndOffset);

        var eventsByDate = {};
        events.forEach(function (ev) {
            if (!eventsByDate[ev.date]) {
                eventsByDate[ev.date] = [];
            }
            eventsByDate[ev.date].push(ev);
        });

        var html = '';
        for (var day = new Date(gridStart); day <= gridEnd; day.setDate(day.getDate() + 1)) {
            var date = toIsoDate(day);
            var inCurrentMonth = day.getMonth() === monthStart.getMonth();
            var dayEvents = eventsByDate[date] || [];
            var className = 'calendar-day';
            if (!inCurrentMonth) {
                className += ' other-month';
            }
            if (inCurrentMonth && dayEvents.length === 0) {
                className += ' empty-current-month';
            }

            html += '<div class="' + className + '" data-date="' + date + '" data-in-month="' + (inCurrentMonth ? '1' : '0') + '" data-has-events="' + (dayEvents.length > 0 ? '1' : '0') + '">';
            html += '<div class="small fw-semibold">' + day.getDate() + '</div>';
            html += '<div class="event-list">';

            dayEvents.forEach(function (ev) {
                var styleAttr = ev.color ? ' style="background:' + escapeHtml(ev.color) + ';"' : '';
                html += '<button type="button" class="event-chip" data-event-id="' + ev.id + '" data-date="' + ev.date + '" data-title="' + escapeHtml(ev.title) + '" data-color="' + escapeHtml(ev.color || '') + '" title="Натисніть, щоб редагувати"' + styleAttr + '>' + escapeHtml(ev.title) + '</button>';
            });

            html += '</div>';
            html += '</div>';
        }

        calendarGrid.innerHTML = html;
        calendarGrid.dataset.currentMonth = toIsoDate(monthStart);
        currentMonthLabel.textContent = formatMonthLabel(monthStart);
    }

    function openCreateModal(date) {
        modalMode = 'create';
        eventIdInput.value = '';
        eventDateInput.value = date;
        eventDateLabel.textContent = date;
        eventTitleInput.value = '';
        eventColorInput.value = '#0d6efd';
        selectedEventTitleRow.classList.add('d-none');
        startEditModeBtn.classList.add('d-none');
        startAddModeBtn.classList.remove('d-none');
        deleteEventBtn.classList.add('d-none');
        setEditorVisible(false);
        eventModal.show();
    }

    function openEditModal(eventData) {
        modalMode = 'edit';
        eventIdInput.value = eventData.id;
        eventDateInput.value = eventData.date;
        eventDateLabel.textContent = eventData.date;
        eventTitleInput.value = eventData.title || '';
        eventColorInput.value = eventData.color || '#0d6efd';
        selectedEventTitle.textContent = eventData.title || '';
        selectedEventTitleRow.classList.remove('d-none');
        startAddModeBtn.classList.add('d-none');
        startEditModeBtn.classList.remove('d-none');
        deleteEventBtn.classList.remove('d-none');
        setEditorVisible(false);
        eventModal.show();
    }

    function loadMonth(monthDate) {
        var targetMonth = toMonthStart(monthDate);
        fetch(getEventsUrl + '?month=' + encodeURIComponent(toIsoDate(targetMonth)))
            .then(function (r) {
                if (!r.ok) {
                    throw new Error('Get events failed');
                }
                return r.json();
            })
            .then(function (data) {
                if (!data.success) {
                    return;
                }
                eventsData = data.events || [];
                currentMonth = targetMonth;
                renderCalendar(currentMonth, eventsData);
            })
            .catch(function () {
                alert('Не вдалося завантажити події для місяця.');
            });
    }

    startAddModeBtn.addEventListener('click', function () {
        setEditorVisible(true);
        saveEventBtn.textContent = 'Зберегти';
        setTimeout(function () { eventTitleInput.focus(); }, 120);
    });

    startEditModeBtn.addEventListener('click', function () {
        setEditorVisible(true);
        saveEventBtn.textContent = 'Зберегти';
        setTimeout(function () { eventTitleInput.focus(); }, 120);
    });

    prevMonthBtn.addEventListener('click', function () {
        loadMonth(new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1, 1));
    });

    nextMonthBtn.addEventListener('click', function () {
        loadMonth(new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 1));
    });

    calendarGrid.addEventListener('click', function (e) {
        var chip = e.target.closest('.event-chip');
        if (chip) {
            var eventId = parseInt(chip.dataset.eventId, 10);
            if (!eventId) {
                return;
            }
            openEditModal({
                id: eventId,
                title: chip.dataset.title || chip.textContent,
                date: chip.dataset.date,
                color: chip.dataset.color
            });
            return;
        }

        var dayCell = e.target.closest('.calendar-day');
        if (!dayCell || dayCell.dataset.inMonth !== '1') {
            return;
        }

        openCreateModal(dayCell.dataset.date);
    });

    deleteEventBtn.addEventListener('click', function () {
        var eventId = parseInt(eventIdInput.value, 10);
        if (!eventId || !confirm('Видалити подію?')) {
            return;
        }

        fetch(deleteEventUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: new URLSearchParams({ id: eventId.toString() })
        })
        .then(function (r) {
            if (!r.ok) {
                throw new Error('Delete failed');
            }
            return r.json();
        })
        .then(function (data) {
            if (!data.success) {
                return;
            }
            eventsData = eventsData.filter(function (x) { return x.id !== eventId; });
            renderCalendar(currentMonth, eventsData);
            eventModal.hide();
        })
        .catch(function () {
            alert('Не вдалося видалити подію.');
        });
    });

    saveEventBtn.addEventListener('click', function () {
        var title = eventTitleInput.value.trim();
        var date = eventDateInput.value;
        var color = eventColorInput.value;
        var eventId = parseInt(eventIdInput.value, 10);

        if (!title) {
            eventTitleInput.focus();
            return;
        }

        var requestUrl = modalMode === 'edit' ? updateEventUrl : createEventUrl;
        var payload = {
            title: title,
            date: date,
            color: color
        };

        if (modalMode === 'edit' && eventId) {
            payload.id = eventId.toString();
        }

        fetch(requestUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: new URLSearchParams(payload)
        })
        .then(function (r) {
            if (!r.ok) {
                throw new Error('Save failed');
            }
            return r.json();
        })
        .then(function (data) {
            if (!data.success) {
                return;
            }

            eventsData = eventsData.filter(function (x) { return x.id !== data.id; });
            eventsData.push(data);
            eventsData.sort(function (a, b) {
                if (a.date === b.date) {
                    return (a.title || '').localeCompare(b.title || '');
                }
                return a.date.localeCompare(b.date);
            });

            if (data.date.substring(0, 7) !== toIsoDate(currentMonth).substring(0, 7)) {
                loadMonth(new Date(data.date + 'T00:00:00'));
            } else {
                renderCalendar(currentMonth, eventsData);
            }
            eventModal.hide();
        })
        .catch(function () {
            alert('Не вдалося зберегти подію.');
        });
    });

    renderCalendar(currentMonth, eventsData);
</script>
}
