@{
    ViewData["Title"] = "Новий клас";
}

<partial name="_AdminNav" />

<h2 class="mb-4">Створити клас</h2>

<form asp-action="CreateClass" method="post" class="col-md-6">
    <div class="mb-3">
        <label class="form-label">Назва класу</label>
        <input name="name" class="form-control" placeholder="Наприклад: 10-А" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Класний керівник</label>
        <select name="teacherId" class="form-select" asp-items="@(ViewData["Teachers"] as SelectList)">
            <option value="">— не вказано —</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Створити</button>
    <a asp-action="Classes" class="btn btn-secondary">Скасувати</a>
</form>
