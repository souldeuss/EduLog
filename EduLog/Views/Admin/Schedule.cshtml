@{
    ViewData["Title"] = "Розклад";

    var years = ViewData["Years"] as List<EduLog.Models.AcademicYear> ?? new();
    var classes = ViewData["Classes"] as List<EduLog.Models.Class> ?? new();
    var selectedYear = ViewData["SelectedYear"] as EduLog.Models.AcademicYear;
    var selectedClass = ViewData["SelectedClass"] as EduLog.Models.Class;
    var slots = ViewData["Slots"] as List<EduLog.Models.ScheduleSlot> ?? new();
    var conflicts = ViewData["Conflicts"] as Dictionary<int, List<string>> ?? new();
    var teachersList = ViewData["Teachers"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var subjectsList = ViewData["Subjects"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;

    var error = TempData["Error"] as string;
    string[] dayNames = { "Понеділок", "Вівторок", "Середа", "Четвер", "П'ятниця" };
}

<partial name="_AdminNav" />

<h2 class="mb-4">Розклад</h2>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle"></i> @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" asp-action="Schedule" class="d-flex gap-3 mb-4 flex-wrap align-items-end">
    <div>
        <label class="form-label">Навчальний рік</label>
        <select name="yearId" class="form-select" onchange="this.form.submit()">
            @foreach (var y in years)
            {
                <option value="@y.Id" selected="@(selectedYear?.Id == y.Id)">
                    @y.Name @(y.IsCurrent ? "★" : "")
                </option>
            }
        </select>
    </div>
    <div>
        <label class="form-label">Клас</label>
        <select name="classId" class="form-select" onchange="this.form.submit()">
            @foreach (var c in classes)
            {
                <option value="@c.Id" selected="@(selectedClass?.Id == c.Id)">@c.Name</option>
            }
        </select>
    </div>
</form>

@if (selectedYear == null || selectedClass == null)
{
    <div class="alert alert-info">Оберіть навчальний рік та клас</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">Урок</th>
                    @for (int d = 1; d <= 5; d++)
                    {
                        <th>@dayNames[d - 1]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int lesson = 1; lesson <= 8; lesson++)
                {
                    <tr>
                        <td><strong>@lesson</strong></td>
                        @for (int day = 1; day <= 5; day++)
                        {
                            var slot = slots.FirstOrDefault(s => s.DayOfWeek == day && s.LessonNumber == lesson);
                            var hasConflict = slot != null && conflicts.ContainsKey(slot.Id);
                            var conflictText = hasConflict ? string.Join("\n", conflicts[slot!.Id]) : "";

                            <td class="@(hasConflict ? "table-danger" : "")"
                                style="min-width:180px; cursor:pointer"
                                data-bs-toggle="modal"
                                data-bs-target="#slotModal"
                                onclick="openSlot(@day, @lesson, @(slot?.Id ?? 0), @(slot?.SubjectId ?? 0), @(slot?.TeacherId ?? 0), '@(slot?.Room ?? "")')">
                                @if (slot != null)
                                {
                                    <div>
                                        <strong>@slot.Subject?.Name</strong><br />
                                        <small class="text-muted">@slot.Teacher?.Surname</small>
                                        @if (!string.IsNullOrEmpty(slot.Room))
                                        {
                                            <br /><small>каб. @slot.Room</small>
                                        }
                                    </div>
                                    @if (hasConflict)
                                    {
                                        <div class="mt-1">
                                            <i class="bi bi-exclamation-triangle text-danger" title="@conflictText"></i>
                                            <small class="text-danger">Конфлікт</small>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">+</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Conflict Legend *@
    @if (conflicts.Any())
    {
        <div class="alert alert-danger mt-3">
            <h6><i class="bi bi-exclamation-triangle"></i> Конфлікти розкладу:</h6>
            <ul class="mb-0">
                @foreach (var kv in conflicts)
                {
                    var conflictSlot = slots.FirstOrDefault(s => s.Id == kv.Key);
                    @foreach (var msg in kv.Value)
                    {
                        <li>
                            @if (conflictSlot != null)
                            {
                                <strong>@dayNames[conflictSlot.DayOfWeek - 1], урок @conflictSlot.LessonNumber</strong>@: @msg
                            }
                            else
                            {
                                @msg
                            }
                        </li>
                    }
                }
            </ul>
        </div>
    }

    @* Modal for adding/editing slot *@
    <div class="modal fade" id="slotModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="SaveSlot" method="post">
                    <input type="hidden" name="yearId" value="@selectedYear.Id" />
                    <input type="hidden" name="classId" value="@selectedClass.Id" />
                    <input type="hidden" name="slotId" id="modalSlotId" />
                    <input type="hidden" name="dayOfWeek" id="modalDay" />
                    <input type="hidden" name="lessonNumber" id="modalLesson" />

                    <div class="modal-header">
                        <h5 class="modal-title" id="modalTitle">Урок</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Предмет</label>
                            <select name="subjectId" id="modalSubject" class="form-select" asp-items="@subjectsList" required></select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Вчитель</label>
                            <select name="teacherId" id="modalTeacher" class="form-select" asp-items="@teachersList" required></select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Кабінет</label>
                            <input name="room" id="modalRoom" class="form-control" maxlength="20" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                        <button type="submit" class="btn btn-primary">Зберегти</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* Delete form (used via JS) *@
    <form id="deleteSlotForm" asp-action="DeleteSlot" method="post" style="display:none">
        <input type="hidden" name="id" id="deleteSlotId" />
        <input type="hidden" name="yearId" value="@selectedYear.Id" />
        <input type="hidden" name="classId" value="@selectedClass.Id" />
    </form>
}

@section Scripts {
    <script>
        var dayNames = ['Понеділок', 'Вівторок', 'Середа', 'Четвер', "П'ятниця"];

        function openSlot(day, lesson, slotId, subjectId, teacherId, room) {
            document.getElementById('modalSlotId').value = slotId || '';
            document.getElementById('modalDay').value = day;
            document.getElementById('modalLesson').value = lesson;
            document.getElementById('modalSubject').value = subjectId || '';
            document.getElementById('modalTeacher').value = teacherId || '';
            document.getElementById('modalRoom').value = room || '';
            document.getElementById('modalTitle').textContent =
                dayNames[day - 1] + ', урок ' + lesson + (slotId ? ' (редагування)' : ' (новий)');
        }
    </script>
}
