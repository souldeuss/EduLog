@{
    ViewData["Title"] = "Розклад";

    var years = ViewData["Years"] as List<EduLog.Models.AcademicYear> ?? new();
    var classes = ViewData["Classes"] as List<EduLog.Models.Class> ?? new();
    var selectedYear = ViewData["SelectedYear"] as EduLog.Models.AcademicYear;
    var selectedClass = ViewData["SelectedClass"] as EduLog.Models.Class;
    var slots = ViewData["Slots"] as List<EduLog.Models.ScheduleSlot> ?? new();
    var conflicts = ViewData["Conflicts"] as Dictionary<int, List<string>> ?? new();
    var teachersList = ViewData["Teachers"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var subjectsList = ViewData["Subjects"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var schedulerModes = ViewData["SchedulerModes"] as List<EduLog.Services.SchedulerModeInfo> ?? new();
    var schedulerOptions = ViewData["SchedulerConfig"] as EduLog.Services.SchedulerConfigOptions ?? new();
    var schedulerApiBaseUrl = ViewData["SchedulerApiBaseUrl"] as string ?? "http://127.0.0.1:8000";
    var lockedSlotIds = (ViewData["LockedSlotIds"] as IEnumerable<int>)?.ToHashSet() ?? new HashSet<int>();
    var classOverview = ViewData["ClassOverview"] as List<EduLog.Models.Admin.ScheduleSubjectOverviewItem> ?? new();
    var subjectColorMap = classOverview.ToDictionary(i => i.SubjectId, i => i.ColorHex ?? "#6C757D");

    var error = TempData["Error"] as string;
    var success = TempData["Success"] as string;
    string[] dayNames = { "Понеділок", "Вівторок", "Середа", "Четвер", "П'ятниця" };
    string[] dayIcons = { "bi-calendar2-week", "bi-calendar2-check", "bi-calendar2-day", "bi-calendar2-event", "bi-calendar2-heart" };
    var slotsPerDay = Enumerable.Range(1, 5)
        .Select(day => slots.Count(s => s.DayOfWeek == day))
        .ToArray();
    var maxDaySlots = Math.Max(1, slotsPerDay.Max());
}

<style>
    .schedule-toolbar {
        position: sticky;
        top: .75rem;
        z-index: 15;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 1rem;
        padding: 1rem;
    }

    .toolbar-separator {
        width: 1px;
        height: 2.25rem;
        background: var(--bs-border-color);
    }

    .schedule-board {
        position: relative;
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid var(--bs-border-color);
    }

    .schedule-board table {
        margin-bottom: 0;
        table-layout: fixed;
    }

    .schedule-board th,
    .schedule-board td {
        vertical-align: top;
    }

    .drop-zone {
        min-height: 116px;
        background: var(--bs-light-bg-subtle);
        border: 2px dashed transparent;
        border-radius: .75rem;
        padding: .5rem;
        transition: all .2s ease;
    }

    .drop-zone.drop-highlight {
        border-color: #86b7fe;
        background: #eff6ff;
    }

    .drop-zone.shake {
        animation: shake .35s ease-in-out;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        20% { transform: translateX(-4px); }
        40% { transform: translateX(4px); }
        60% { transform: translateX(-4px); }
        80% { transform: translateX(4px); }
    }

    .add-slot-btn {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        padding: 0;
        line-height: 1;
    }

    .lesson-card {
        border-radius: .75rem;
        padding: .5rem .5rem .5rem .4rem;
        border: 1px solid rgba(0, 0, 0, .08);
        background: hsl(var(--subject-hue, 200) 75% 92%);
        cursor: grab;
        position: relative;
    }

    .lesson-card:active {
        cursor: grabbing;
    }

    .lesson-card.is-locked {
        cursor: not-allowed;
        opacity: .7;
    }

    .lesson-card.is-conflict {
        border: 2px solid #dc3545;
    }

    .lesson-card-subject {
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 150px;
    }

    .drag-handle {
        cursor: grab;
        color: var(--bs-secondary-color);
        width: 16px;
    }

    .card-actions {
        opacity: 0;
        transition: opacity .15s ease;
    }

    .lesson-card:hover .card-actions {
        opacity: 1;
    }

    .board-loading {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, .65);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 5;
        backdrop-filter: blur(2px);
    }

    .board-loading.active {
        display: flex;
    }

    .stats-day {
        display: grid;
        grid-template-columns: 100px 1fr 38px;
        align-items: center;
        gap: .5rem;
        margin-bottom: .45rem;
    }

    .stats-bar {
        height: 8px;
        border-radius: 999px;
        background: #e9ecef;
        overflow: hidden;
    }

    .stats-bar > span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, #0d6efd, #20c997);
    }

    .schedule-layout .weekly-overview-wrap {
        position: relative;
    }

    .weekly-overview-panel {
        position: sticky;
        top: 1rem;
        border: 1px solid var(--bs-border-color);
        border-radius: 1rem;
        box-shadow: 0 .35rem 1.2rem rgba(0, 0, 0, .06);
        background: var(--bs-body-bg);
    }

    .weekly-overview-list {
        max-height: 68vh;
        overflow-y: auto;
    }

    .subject-overview-item {
        border: 1px solid var(--bs-border-color-translucent);
        border-radius: .75rem;
        padding: .65rem .75rem;
        background: var(--bs-tertiary-bg);
    }

    .subject-overview-item.is-over {
        border-color: rgba(220, 53, 69, .45);
        background: rgba(220, 53, 69, .06);
    }

    .subject-overview-title {
        font-weight: 600;
        line-height: 1.2;
    }

    .subject-color-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        border: 1px solid rgba(0, 0, 0, .12);
    }

    .subject-overview-counter {
        font-size: .82rem;
        font-weight: 600;
    }

    .subject-overview-status {
        font-size: .75rem;
        min-height: 1rem;
    }

    /* SortableJS visual states */
    .drop-zone.sortable-over {
        border-color: #86b7fe;
        background: #eff6ff;
    }

    #subjectSidebar .subject-overview-item {
        cursor: grab;
        transition: box-shadow .15s, transform .15s;
    }

    #subjectSidebar .subject-overview-item:hover {
        box-shadow: 0 3px 10px rgba(0, 0, 0, .1);
        transform: translateY(-1px);
    }

    #subjectSidebar .subject-overview-item.sortable-chosen {
        cursor: grabbing;
        box-shadow: 0 6px 20px rgba(0, 0, 0, .15);
        transform: scale(1.02);
        z-index: 10;
    }

    #subjectSidebar .subject-overview-item.sortable-ghost {
        opacity: 0.35;
    }

    .drag-hint {
        font-size: .73rem;
        color: var(--bs-secondary-color);
        margin-top: .2rem;
    }

    .remaining-badge {
        font-size: .7rem;
        font-weight: 600;
        min-width: 1.6em;
    }

    /* ── Teacher view ── */
    .teacher-lesson-card {
        border-radius: .65rem;
        padding: .4rem .55rem;
        border: 1px solid var(--bs-border-color-translucent);
        background: var(--bs-tertiary-bg);
        cursor: default;
        user-select: none;
    }

    .teacher-lesson-class {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--bs-secondary-color);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .teacher-lesson-subject {
        font-weight: 600;
        font-size: .88rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .teacher-lesson-room {
        font-size: .73rem;
        color: var(--bs-secondary-color);
    }

    .teacher-drop-zone {
        min-height: 80px;
        border-radius: .65rem;
        padding: .35rem;
    }

    .teacher-stats-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .32rem 0;
        border-bottom: 1px solid var(--bs-border-color-translucent);
        font-size: .84rem;
    }

    .teacher-stats-item:last-child {
        border-bottom: none;
    }

    #viewModeBar .btn {
        font-size: .85rem;
    }

    #teacherBoard {
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid var(--bs-border-color);
    }

    #teacherBoard table {
        margin-bottom: 0;
        table-layout: fixed;
    }

    #teacherBoard th,
    #teacherBoard td {
        vertical-align: top;
    }
</style>

<partial name="_AdminNav" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Розклад</h2>
    <button class="btn btn-outline-secondary position-relative" type="button" data-bs-toggle="offcanvas" data-bs-target="#scheduleSidePanel">
        <i class="bi bi-layout-sidebar-inset"></i> Панель
        <span id="conflictBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger @(conflicts.Any() ? "" : "d-none")">
            @conflicts.Count
        </span>
    </button>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle"></i> @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(success))
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form id="scheduleFilterForm" method="get" asp-action="Schedule" class="schedule-toolbar d-flex flex-wrap align-items-end gap-3 mb-4">
    <div>
        <label class="form-label small text-muted mb-1">Навчальний рік</label>
        <select name="yearId" class="form-select" onchange="this.form.submit()">
            @foreach (var y in years)
            {
                <option value="@y.Id" selected="@(selectedYear?.Id == y.Id)">@y.Name @(y.IsCurrent ? "★" : "")</option>
            }
        </select>
    </div>

    <div>
        <label class="form-label small text-muted mb-1">Клас</label>
        <select name="classId" class="form-select" onchange="this.form.submit()">
            @foreach (var c in classes)
            {
                <option value="@c.Id" selected="@(selectedClass?.Id == c.Id)">@c.Name</option>
            }
        </select>
    </div>

    <div class="toolbar-separator d-none d-lg-block"></div>

    <button class="btn btn-success" type="button" data-bs-toggle="modal" data-bs-target="#generateModal" @(selectedYear == null ? "disabled" : null)>
        <i class="bi bi-stars"></i> Згенерувати розклад для всього року
    </button>

    <button id="saveChangesBtn" class="btn btn-primary d-none" type="button">
        <i class="bi bi-floppy"></i> Зберегти зміни
    </button>

    <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" @(selectedYear == null ? "disabled" : null)>
            Експорт
        </button>
        <ul class="dropdown-menu">
            @if (selectedYear != null)
            {
                <li><a class="dropdown-item" href="@Url.Action("ExportSchedule", "Admin", new { yearId = selectedYear.Id, format = "json" })">JSON</a></li>
                <li><a class="dropdown-item" href="@Url.Action("ExportSchedule", "Admin", new { yearId = selectedYear.Id, format = "csv" })">CSV</a></li>
            }
        </ul>
    </div>

    <button id="importBtn" class="btn btn-outline-primary" type="button" @(selectedYear == null ? "disabled" : null)>
        <i class="bi bi-upload"></i> Імпорт
    </button>

    <button id="clearScheduleBtn" class="btn btn-outline-danger" type="button" @(selectedYear == null ? "disabled" : null) data-bs-toggle="modal" data-bs-target="#clearScheduleModal">
        <i class="bi bi-trash"></i> Очистити розклад
    </button>

    <button id="discardChangesBtn" class="btn btn-danger d-none" type="button">
        <i class="bi bi-x-circle"></i> Скасувати всі зміни
    </button>
</form>

@if (selectedYear == null || selectedClass == null)
{
    <div class="alert alert-info">Оберіть навчальний рік та клас</div>
}
else
{
    <div id="viewModeBar" class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div class="btn-group btn-group-sm" role="group" aria-label="Режим перегляду">
            <button type="button" id="btnViewClass" class="btn btn-primary">
                <i class="bi bi-grid-3x3-gap-fill"></i> За класом
            </button>
            <button type="button" id="btnViewTeacher" class="btn btn-outline-primary">
                <i class="bi bi-person-badge-fill"></i> За вчителем
            </button>
        </div>
        <div id="teacherSelectorWrap" class="d-none align-items-center gap-2">
            <i class="bi bi-person-badge text-muted fs-5"></i>
            <select id="teacherViewSelect" class="form-select form-select-sm" style="min-width: 220px;">
                <option value="">— оберіть вчителя —</option>
                @if (teachersList != null)
                {
                    @foreach (var t in teachersList)
                    {
                        <option value="@t.Value">@t.Text</option>
                    }
                }
            </select>
            <span id="teacherViewLoading" class="spinner-border spinner-border-sm text-primary d-none" role="status" aria-label="Завантаження..."></span>
        </div>
    </div>

    <div class="row g-3 schedule-layout mb-4">
        <aside class="col-12 col-xl-3">
            <div id="weeklyOverviewPanel" class="card weekly-overview-panel">
                <div id="classViewHeader" class="card-header bg-transparent border-0 pb-0">
                    <h6 class="mb-1">Предмети</h6>
                    <p class="text-muted small mb-0">@selectedClass.Name · Призначено / Потрібно</p>
                    <p class="drag-hint mb-0"><i class="bi bi-arrows-move"></i> Перетягніть предмет у розклад</p>
                </div>
                <div id="teacherViewHeader" class="card-header bg-transparent border-0 pb-0 d-none">
                    <h6 class="mb-1" id="teacherViewName">Вчитель</h6>
                    <p class="text-muted small mb-0">Тижневий розклад</p>
                </div>
                <div class="card-body pt-3 weekly-overview-list d-flex flex-column gap-2" id="subjectSidebar">
                    @if (classOverview.Any())
                    {
                        @foreach (var item in classOverview)
                        {
                            var requiredLessons = Math.Max(0, item.RequiredLessons);
                            var assignedLessons = Math.Max(0, item.AssignedLessons);
                            var remaining = requiredLessons - assignedLessons;
                            var progressPercent = requiredLessons > 0
                                ? Math.Min(100, (int)Math.Round(assignedLessons * 100.0 / requiredLessons))
                                : (assignedLessons > 0 ? 100 : 0);
                            var isOverScheduled = assignedLessons > requiredLessons;
                            var itemColor = item.ColorHex ?? "#6C757D";
                            var remainingBadgeClass = isOverScheduled ? "bg-danger" : (remaining == 0 ? "bg-secondary" : "bg-primary");

                            <div class="subject-overview-item @(isOverScheduled ? "is-over" : "")"
                                 data-subject-id="@item.SubjectId"
                                 data-subject-name="@item.SubjectName"
                                 data-required="@requiredLessons"
                                 data-assigned="@assignedLessons"
                                 data-subject-color="@itemColor">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <div class="d-flex align-items-center gap-2 min-w-0">
                                        <span class="subject-color-dot" style="background-color:@itemColor"></span>
                                        <span class="subject-overview-title text-truncate">@item.SubjectName</span>
                                    </div>
                                    <div class="d-flex flex-column align-items-end gap-1">
                                        <span class="subject-overview-counter @(isOverScheduled ? "text-danger" : "text-muted")">@assignedLessons/@requiredLessons</span>
                                        <span class="badge @remainingBadgeClass remaining-badge">@(remaining > 0 ? $"+{remaining}" : remaining.ToString())</span>
                                    </div>
                                </div>
                                <div class="progress" style="height: 7px;">
                                    <div class="progress-bar @(isOverScheduled ? "bg-danger" : "")"
                                         role="progressbar"
                                         style="width:@progressPercent%;@(isOverScheduled ? string.Empty : $"background-color:{itemColor};")"
                                         aria-valuenow="@assignedLessons"
                                         aria-valuemin="0"
                                         aria-valuemax="@Math.Max(1, requiredLessons)"></div>
                                </div>
                                <div class="subject-overview-status mt-1 @(isOverScheduled ? "text-danger" : "text-muted")">
                                    @(isOverScheduled ? $"Перевищення: +{assignedLessons - requiredLessons}" : "У межах норми")
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-light border mb-0 small">Для цього класу ще не налаштовано предмети в навчальному плані.</div>
                    }
                </div>

                <div class="card-body pt-2 weekly-overview-list d-none" id="teacherStatsSidebar">
                    <div id="teacherStatsContent">
                        <p class="text-muted small mb-0">Оберіть вчителя для перегляду статистики.</p>
                    </div>
                </div>
            </div>
        </aside>

        <div class="col-12 col-xl-9">
            <div class="schedule-board shadow-sm" id="scheduleBoard">
                <div class="board-loading" id="boardLoading">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status"></div>
                        <div class="mt-2 fw-semibold">Генеруємо розклад...</div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:78px">Урок</th>
                                @for (int d = 1; d <= 5; d++)
                                {
                                    <th>
                                        <i class="bi @dayIcons[d - 1] text-primary"></i>
                                        @dayNames[d - 1]
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody id="scheduleBody">
                            @for (int lesson = 1; lesson <= 8; lesson++)
                            {
                                <tr>
                                    <td class="fw-semibold text-center">@lesson</td>
                                    @for (int day = 1; day <= 5; day++)
                                    {
                                        var slot = slots.FirstOrDefault(s => s.DayOfWeek == day && s.LessonNumber == lesson);
                                        var hasConflict = slot != null && conflicts.ContainsKey(slot.Id);
                                        var conflictText = hasConflict ? string.Join(" | ", conflicts[slot!.Id]) : string.Empty;
                                        var isLocked = slot != null && lockedSlotIds.Contains(slot.Id);
                                        var subjectColor = slot != null && subjectColorMap.TryGetValue(slot.SubjectId, out var mappedColor)
                                            ? mappedColor
                                            : "#6C757D";
                                        <td>
                                            <div class="drop-zone"
                                                 data-day="@day"
                                                 data-lesson="@lesson"
                                                 data-slot-id="@(slot?.Id ?? 0)">
                                                @if (slot != null)
                                                {
                                                    <div class="lesson-card @(hasConflict ? "is-conflict" : "") @(isLocked ? "is-locked" : "")"
                                                         data-slot-id="@slot.Id"
                                                         data-day="@slot.DayOfWeek"
                                                         data-lesson="@slot.LessonNumber"
                                                         data-subject-id="@slot.SubjectId"
                                                         data-teacher-id="@slot.TeacherId"
                                                         data-subject-name="@slot.Subject?.Name"
                                                         data-subject-color="@subjectColor"
                                                         data-teacher-name="@slot.Teacher?.Surname"
                                                         data-room="@slot.Room"
                                                         data-conflict="@(hasConflict ? "1" : "0")"
                                                         data-locked="@(isLocked ? "1" : "0")"
                                                         title="@conflictText">
                                                        <div class="d-flex align-items-start gap-2">
                                                            <span class="drag-handle">≡</span>
                                                            <div class="flex-grow-1 overflow-hidden">
                                                                <div class="lesson-card-subject">@slot.Subject?.Name</div>
                                                                <div class="small text-muted">@slot.Teacher?.Surname</div>
                                                                @if (!string.IsNullOrWhiteSpace(slot.Room))
                                                                {
                                                                    <div class="small text-muted">каб. @slot.Room</div>
                                                                }
                                                            </div>
                                                            <div class="d-flex flex-column align-items-end">
                                                                @if (isLocked)
                                                                {
                                                                    <span title="Locked">🔒</span>
                                                                }
                                                                @if (hasConflict)
                                                                {
                                                                    <span title="Конфлікт">⚠️</span>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="card-actions d-flex justify-content-end gap-1 mt-2">
                                                            <button type="button" class="btn btn-sm btn-light border edit-slot-btn">✏️ Редагувати</button>
                                                            <button type="button" class="btn btn-sm btn-outline-danger delete-slot-btn">🗑️ Видалити</button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-secondary add-slot-btn">+</button>
                                                }
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* Teacher view board (read-only, populated via JS) *@
            <div id="teacherBoard" class="schedule-board shadow-sm d-none mt-0">
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:78px">Урок</th>
                                @for (int d = 1; d <= 5; d++)
                                {
                                    <th>
                                        <i class="bi @dayIcons[d - 1] text-primary"></i>
                                        @dayNames[d - 1]
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody id="teacherScheduleBody">
                            @for (int lesson = 1; lesson <= 8; lesson++)
                            {
                                <tr>
                                    <td class="fw-semibold text-center">@lesson</td>
                                    @for (int day = 1; day <= 5; day++)
                                    {
                                        <td>
                                            <div class="teacher-drop-zone"
                                                 data-day="@day"
                                                 data-lesson="@lesson">
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<form id="importForm" asp-action="ImportSchedule" method="post" enctype="multipart/form-data" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="yearId" value="@(selectedYear?.Id ?? 0)" />
    <input id="importFileInput" type="file" name="file" accept=".json,.csv" />
</form>

<div class="offcanvas offcanvas-end" tabindex="-1" id="scheduleSidePanel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title">Аналітика розкладу</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <div class="mb-4">
            <h6 class="d-flex align-items-center gap-2">
                <span>⚠️ Конфлікти</span>
                <span class="badge text-bg-danger" id="sideConflictCount">@conflicts.Count</span>
            </h6>
            @if (conflicts.Any())
            {
                <ul class="small ps-3 mb-0">
                    @foreach (var kv in conflicts)
                    {
                        var conflictSlot = slots.FirstOrDefault(s => s.Id == kv.Key);
                        foreach (var msg in kv.Value)
                        {
                            <li class="mb-2">
                                @if (conflictSlot != null)
                                {
                                    <strong>@dayNames[conflictSlot.DayOfWeek - 1], урок @conflictSlot.LessonNumber:</strong> @msg
                                }
                                else
                                {
                                    @msg
                                }
                            </li>
                        }
                    }
                </ul>
            }
            else
            {
                <p class="text-muted small mb-0">Конфліктів не знайдено.</p>
            }
        </div>

        <div>
            <h6 class="mb-3">Статистика по днях</h6>
            <div id="statsContainer">
                @for (int d = 1; d <= 5; d++)
                {
                    var value = slotsPerDay[d - 1];
                    var widthPercent = (int)Math.Round(value * 100.0 / maxDaySlots);
                    <div class="stats-day" data-day="@d">
                        <span class="small">@dayNames[d - 1]</span>
                        <div class="stats-bar"><span style="width:@widthPercent%"></span></div>
                        <span class="small text-end day-count">@value</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="generateModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form id="generateForm" asp-action="GenerateAiSchedule" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="yearId" value="@(selectedYear?.Id ?? 0)" />
                <input type="hidden" name="classId" value="@(selectedClass?.Id ?? 0)" />
                <input type="hidden" name="options.PlanningPeriodWeeks" value="@schedulerOptions.PlanningPeriodWeeks" />
                <input type="hidden" name="options.MaxDuplicatesPerDay" value="@schedulerOptions.MaxDuplicatesPerDay" />

                <div class="modal-header">
                    <h5 class="modal-title">Генерація розкладу для всіх класів</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small mb-3">
                        Генерація буде виконана для всіх класів вибраного навчального року. Поточний клас на сторінці впливає лише на перегляд.
                    </div>

                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var mode in schedulerModes)
                        {
                            var icon = mode.Mode switch
                            {
                                EduLog.Services.SchedulerMode.Balanced => "⚖️",
                                EduLog.Services.SchedulerMode.Dense => "⚡",
                                EduLog.Services.SchedulerMode.Append => "🧩",
                                _ => "✨"
                            };
                            <label class="border rounded p-3">
                                <input class="form-check-input me-2" type="radio" name="mode" value="@mode.Mode" @(mode == schedulerModes.FirstOrDefault() ? "checked" : null) />
                                <strong>@icon @mode.Name</strong>
                                <div class="small text-muted mt-1">@mode.Description</div>
                            </label>
                        }
                    </div>

                    <div class="accordion" id="generateAdvancedAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="advancedSettingsHeading">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#advancedSettingsCollapse">
                                    Додаткові налаштування
                                </button>
                            </h2>
                            <div id="advancedSettingsCollapse" class="accordion-collapse collapse" data-bs-parent="#generateAdvancedAccordion">
                                <div class="accordion-body">
                                    <label class="form-label d-flex justify-content-between">
                                        <span>Макс. уроків за день</span>
                                        <span id="maxLessonsValue">@schedulerOptions.MaxLessonsPerDay</span>
                                    </label>
                                    <input id="maxLessonsRange" class="form-range" type="range" min="3" max="8" name="options.MaxLessonsPerDay" value="@Math.Clamp(schedulerOptions.MaxLessonsPerDay, 3, 8)" />

                                    <label class="form-label d-flex justify-content-between mt-3">
                                        <span>К-сть ітерацій ШІ</span>
                                        <span id="iterationsValue">@schedulerOptions.Iterations</span>
                                    </label>
                                    <input id="iterationsRange" class="form-range" type="range" min="10" max="500" step="10" name="options.Iterations" value="@Math.Clamp(schedulerOptions.Iterations, 10, 500)" />

                                    <label class="form-label mt-3" for="learningRateInput">Learning rate</label>
                                    <input id="learningRateInput" class="form-control" type="number" min="0.000001" max="0.1" step="0.000001" name="options.LearningRate" value="@schedulerOptions.LearningRate.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    <div class="form-text">За замовчуванням: 0.02. Поле можна змінювати вручну.</div>

                                    <div class="form-check form-switch mt-3">
                                        <input class="form-check-input" type="checkbox" id="allowDuplicatesSwitch" name="options.AllowDuplicates" value="true" @(schedulerOptions.AllowDuplicates ? "checked" : null) />
                                        <label class="form-check-label" for="allowDuplicatesSwitch">Дозволити повтори предмету в день</label>
                                    </div>

                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" id="allowGapsSwitch" name="options.AllowGaps" value="true" @(schedulerOptions.AllowGaps ? "checked" : null) />
                                        <label class="form-check-label" for="allowGapsSwitch">Дозволити вікна</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="generateProgressWrap" class="mt-4 d-none">
                        <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                            <div id="generateProgress" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%">0%</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button id="generateSubmitBtn" type="submit" class="btn btn-success">Згенерувати</button>
                </div>
            </form>
        </div>
    </div>
</div>

