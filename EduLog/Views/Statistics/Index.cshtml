@using EduLog.Models
@{
    ViewData["Title"] = "Статистика";

    var classes = ViewBag.Classes as List<Class> ?? new List<Class>();
    var selectedClass = ViewBag.SelectedClass as Class;
    var subjects = ViewBag.Subjects as List<Subject> ?? new List<Subject>();
    var academicYears = ViewBag.AcademicYears as List<AcademicYear> ?? new List<AcademicYear>();
}

<h2 class="mb-4"><i class="bi bi-bar-chart-line"></i> Статистика</h2>

@if (selectedClass == null)
{
    <div class="alert alert-info">Немає класів, для яких ви ведете предмети.</div>
}
else
{
    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Клас</label>
                    <select id="f-class" class="form-select">
                        @foreach (var c in classes)
                        {
                            <option value="@c.Id" selected="@(c.Id == selectedClass.Id)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Предмет</label>
                    <select id="f-subject" class="form-select">
                        <option value="">Усі</option>
                        @foreach (var s in subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Дата від</label>
                    <input id="f-from" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Дата до</label>
                    <input id="f-to" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Навч. рік</label>
                    <select id="f-year" class="form-select">
                        <option value="">—</option>
                        @foreach (var y in academicYears)
                        {
                            <option value="@y.Id" selected="@(y.IsCurrent)">@y.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button id="applyBtn" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-check2"></i> Застосувати
                    </button>
                    <button id="csvBtn" class="btn btn-outline-success" title="Завантажити CSV">
                        <i class="bi bi-filetype-csv"></i>
                    </button>
                    <a id="adaptiveReportBtn" class="btn btn-outline-primary" title="Адаптивний звіт (XLSX)"
                       asp-action="ExportAdaptiveReport" asp-route-classId="">
                        <i class="bi bi-clipboard-data"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Tiles -->
    <div class="row g-3 mb-4" id="tiles">
        <div class="col-md-3 col-sm-6">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <div class="text-muted small">Середня по класу</div>
                    <div class="display-6 fw-bold text-primary" id="t-avg">—</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Розподіл учнів</div>
                    <div class="d-flex justify-content-around mt-2">
                        <div class="text-center">
                            <div class="badge bg-success fs-6" id="t-high">0</div>
                            <div class="small text-muted mt-1">≥ 10</div>
                        </div>
                        <div class="text-center">
                            <div class="badge bg-warning text-dark fs-6" id="t-mid">0</div>
                            <div class="small text-muted mt-1">7–9</div>
                        </div>
                        <div class="text-center">
                            <div class="badge bg-danger fs-6" id="t-low">0</div>
                            <div class="small text-muted mt-1">&lt; 7</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-info h-100">
                <div class="card-body">
                    <div class="text-muted small">Відвідуваність</div>
                    <div class="display-6 fw-bold text-info" id="t-att">—</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Домашні завдання</div>
                    <div class="mt-2">
                        <span class="badge bg-success fs-6" id="t-hw-ok">0</span>
                        <span class="small text-muted">здано</span>
                    </div>
                    <div class="mt-1">
                        <span class="badge bg-secondary fs-6" id="t-hw-no">0</span>
                        <span class="small text-muted">не здано</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">Динаміка середньої по місяцях</h6>
                    <canvas id="lineChart" height="180"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">Розподіл оцінок (1–12)</h6>
                    <canvas id="histChart" height="180"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">Відвідуваність</h6>
                    <canvas id="pieChart" height="180"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">Учні</h6>
                    <div class="table-responsive" style="max-height:340px; overflow-y:auto;">
                        <table class="table table-sm table-hover mb-0" id="studentsTable">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="cursor:pointer" data-sort="name">Ім'я <span class="sort-arrow"></span></th>
                                    <th style="cursor:pointer" data-sort="avg">Сер. <span class="sort-arrow"></span></th>
                                    <th style="cursor:pointer" data-sort="count">Оцінок <span class="sort-arrow"></span></th>
                                    <th style="cursor:pointer" data-sort="att">Відвід. % <span class="sort-arrow"></span></th>
                                    <th style="cursor:pointer" data-sort="trend">Тренд <span class="sort-arrow"></span></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        let lineChart, histChart, pieChart;
        let currentStudents = [];
        let sortKey = 'name';
        let sortDir = 1; // 1 asc, -1 desc

        function getFilters() {
            return {
                classId: document.getElementById('f-class').value,
                subjectId: document.getElementById('f-subject').value,
                dateFrom: document.getElementById('f-from').value,
                dateTo: document.getElementById('f-to').value,
                academicYearId: document.getElementById('f-year').value
            };
        }

        function buildQuery(f) {
            const p = new URLSearchParams();
            if (f.classId) p.append('classId', f.classId);
            if (f.subjectId) p.append('subjectId', f.subjectId);
            if (f.dateFrom) p.append('dateFrom', f.dateFrom);
            if (f.dateTo) p.append('dateTo', f.dateTo);
            if (f.academicYearId) p.append('academicYearId', f.academicYearId);
            return p.toString();
        }

        async function loadData() {
            const f = getFilters();
            if (!f.classId) return;
            const res = await fetch('@Url.Action("Data", "Statistics")?' + buildQuery(f));
            if (!res.ok) { alert('Помилка завантаження статистики'); return; }
            const d = await res.json();
            renderTiles(d.tiles);
            renderLine(d.monthlyAvg);
            renderHist(d.histogram);
            renderPie(d.attendance);
            currentStudents = d.students || [];
            renderTable();
        }

        function renderTiles(t) {
            document.getElementById('t-avg').textContent = (t.avgGrade || 0).toFixed(2);
            document.getElementById('t-high').textContent = t.high;
            document.getElementById('t-mid').textContent = t.mid;
            document.getElementById('t-low').textContent = t.low;
            document.getElementById('t-att').textContent = (t.attendancePct || 0).toFixed(1) + '%';
            document.getElementById('t-hw-ok').textContent = t.hwSubmitted;
            document.getElementById('t-hw-no').textContent = t.hwNotSubmitted;
        }

        function renderLine(line) {
            const ctx = document.getElementById('lineChart');
            if (lineChart) lineChart.destroy();
            lineChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: line.labels,
                    datasets: [{
                        label: 'Середня',
                        data: line.data,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13,110,253,0.15)',
                        tension: 0.3,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    scales: { y: { beginAtZero: true, max: 12 } },
                    plugins: { legend: { display: false } }
                }
            });
        }

        function renderHist(hist) {
            const ctx = document.getElementById('histChart');
            if (histChart) histChart.destroy();
            const labels = Array.from({length: 12}, (_, i) => (i + 1).toString());
            histChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [{
                        label: 'Кількість оцінок',
                        data: hist,
                        backgroundColor: labels.map((_, i) => i < 3 ? '#dc3545' : i < 6 ? '#fd7e14' : i < 9 ? '#0d6efd' : '#198754'),
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                    plugins: { legend: { display: false } }
                }
            });
        }

        function renderPie(a) {
            const ctx = document.getElementById('pieChart');
            if (pieChart) pieChart.destroy();
            pieChart = new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: ['Присутні', 'Відсутні'],
                    datasets: [{
                        data: [a.present, a.absent],
                        backgroundColor: ['#198754', '#dc3545']
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        }

        function renderTable() {
            const tbody = document.querySelector('#studentsTable tbody');
            const sorted = [...currentStudents].sort((a, b) => {
                let va, vb;
                switch (sortKey) {
                    case 'avg': va = a.avg; vb = b.avg; break;
                    case 'count': va = a.gradeCount; vb = b.gradeCount; break;
                    case 'att': va = a.attendancePct; vb = b.attendancePct; break;
                    case 'trend': va = a.trend; vb = b.trend; break;
                    default: va = a.name; vb = b.name;
                }
                if (va < vb) return -1 * sortDir;
                if (va > vb) return 1 * sortDir;
                return 0;
            });
            tbody.innerHTML = sorted.map(s => {
                let rowClass = '';
                if (s.gradeCount > 0 && s.avg < 4) rowClass = 'table-danger';
                else if (s.avg >= 10) rowClass = 'table-success';
                const trendIcon = s.trend === 1 ? '<span class="text-success">↑</span>'
                                  : s.trend === -1 ? '<span class="text-danger">↓</span>'
                                  : '<span class="text-muted">→</span>';
                return `<tr class="${rowClass}">
                    <td>${escapeHtml(s.name)}</td>
                    <td>${s.avg.toFixed(1)}</td>
                    <td>${s.gradeCount}</td>
                    <td>${s.attendancePct.toFixed(1)}%</td>
                    <td>${trendIcon}</td>
                </tr>`;
            }).join('');

            // Update sort arrows
            document.querySelectorAll('#studentsTable thead th').forEach(th => {
                const arrow = th.querySelector('.sort-arrow');
                if (!arrow) return;
                arrow.textContent = th.dataset.sort === sortKey ? (sortDir === 1 ? '▲' : '▼') : '';
            });
        }

        function escapeHtml(s) {
            return (s || '').replace(/[&<>"']/g, c => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
            }[c]));
        }

        document.querySelectorAll('#studentsTable thead th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const k = th.dataset.sort;
                if (sortKey === k) sortDir = -sortDir;
                else { sortKey = k; sortDir = 1; }
                renderTable();
            });
        });

        document.getElementById('applyBtn').addEventListener('click', loadData);

        document.getElementById('f-class').addEventListener('change', async () => {
            const cid = document.getElementById('f-class').value;
            const res = await fetch('@Url.Action("SubjectsForClass", "Statistics")?classId=' + cid);
            if (res.ok) {
                const list = await res.json();
                const sel = document.getElementById('f-subject');
                sel.innerHTML = '<option value="">Усі</option>' +
                    list.map(s => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('');
            }
            loadData();
        });

        document.getElementById('csvBtn').addEventListener('click', () => {
            const q = buildQuery(getFilters());
            window.location.href = '@Url.Action("ExportCsv", "Statistics")?' + q;
        });

        // Адаптивний звіт — параметризується лише classId, береться з поточного фільтра.
        document.getElementById('adaptiveReportBtn').addEventListener('click', (e) => {
            e.preventDefault();
            const cid = document.getElementById('f-class').value;
            if (!cid) return;
            window.location.href = '@Url.Action("ExportAdaptiveReport", "Statistics")?classId=' + cid;
        });

        // Initial load
        loadData();
    </script>
}
